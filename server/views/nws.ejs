<nav class="navbar navbar-dark custom-navbar">
  <div class="container">
    <span class="navbar-brand mb-0 h1">Nieuwsbeheer</span>
  </div>
</nav>

<main class="container py-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="page-title mb-0">Lijst van nieuwsartikelen</h1>
    <a href="/nws_edit" class="btn btn-primary">Nieuw / Bewerken</a>
  </div>

  <div class="card custom-card mb-4">
    <div class="card-body">
      <form class="row g-2">
        <div class="col-md-10">
          <input
            type="text"
            class="form-control"
            placeholder="Zoek op titel of auteur"
          />
        </div>
        <div class="col-md-2 d-grid">
          <button type="submit" class="btn btn-outline-primary">Zoeken</button>
        </div>
      </form>
    </div>
  </div>

  <div class="card custom-card">
    <div class="card-body">
      <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
          <thead class="table-dark">
            <tr>
              <th>ID</th>
              <th>Titel</th>
              <th>Auteur</th>
              <th>Categorie</th>
              <th>Publicatiedatum</th>
              <th>Status</th>
              <th>Acties</th>
            </tr>
          </thead>
          <tbody>
            <% News.forEach(news => { %>
                         <tr>
              <td><%=news.id%></td>
              <td><%=news.title%></td>
              <td><%=news.author%></td>
              <td><%=news.category%></td>
              <td><%=news.published_date%></td>
              <td><span class="badge bg-success">Gepubliceerd</span></td>
              <td>
                <a href="/nws_edit/<%=news.id%>" class="btn btn-sm btn-warning">Bewerk</a>
              </td>
            </tr>
                <% }) %>
          </tbody>
        </table>
      </div>

      <nav aria-label="Paginatie" class="mt-4">
        <ul class="pagination justify-content-center mb-0">
          <li class="page-item disabled">
            <a class="page-link" href="#">Vorige</a>
          </li>
          <li class="page-item active">
            <a class="page-link" href="#">1</a>
          </li>
          <li class="page-item">
            <a class="page-link" href="#">2</a>
          </li>
          <li class="page-item">
            <a class="page-link" href="#">3</a>
          </li>
          <li class="page-item">
            <a class="page-link" href="#">Volgende</a>
          </li>
        </ul>
      </nav>
    </div>
  </div>
</main>
